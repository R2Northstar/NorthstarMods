// respawn uses this to track a bunch of server stuff like player connections, player disconnects,
// game start, game end, round start, round end, game errors, etc to a pin telemetry host `pin_telemetry_hostname`
// `pin_telemetry_debug` `pin_telemetry_debug_script`
// script AddPINTelemetryEvent( "game_action", PIN_StandardServerHeader(), { errid = "Error string", type = "Error type" } )

