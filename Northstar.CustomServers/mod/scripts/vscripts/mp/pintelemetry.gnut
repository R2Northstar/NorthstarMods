table function PIN_StandardServerHeader()
{
	string matchid = lstrip( rstrip( GameRules_GetUniqueMatchID() ) )

	return {
		game_type = "online",
		game_mode = GAMETYPE,
		mode_type = "multiplayer",
		map = GetMapName(),
		platform_name = GetPINPlatformName(),
		custom = { mid = matchid, players = GetPlayerArray().len(), server_id = GetConVarString( "serverFilter" ) },
	}
}
